# === Optional: Anthropic API fallback ===
# Only used if no API key is configured in Settings > AI tab.
# Most users should set their LLM key in the dashboard instead.
# ANTHROPIC_API_KEY=

# === Optional: Claude Code (uses Max/Pro subscription instead of API credits) ===
# Generate with: claude setup-token
# CLAUDE_CODE_OAUTH_TOKEN=

# === Optional: Telegram Notifications (get token from @BotFather) ===
# TELEGRAM_BOT_TOKEN=

# === Optional: Gmail Monitoring (one-time OAuth2 setup) ===
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=

# === Database (defaults work with docker-compose) ===
DATABASE_URL=postgresql://jobnavigator:password@db:5432/jobnavigator

# === Dashboard Password (empty = no auth on first run) ===
# INITIAL_API_KEY=
